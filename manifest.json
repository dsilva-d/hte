{
  "manifest_version": 3,
  "name": "Hawk Tuah Replacer",
  "version": "2.2.1",
  "description": "Replaces likely nouns with 'hawk' and likely verbs with 'tuah' while leaving adjectives alone on web pages.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Hawk Tuah Replacer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}